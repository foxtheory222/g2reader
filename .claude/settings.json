{
  "extraKnownMarketplaces": {
    "everything-evenhub": {
      "source": { "source": "github", "repo": "even-realities/everything-evenhub" }
    }
  },
  "enabledPlugins": { "everything-evenhub@everything-evenhub": true },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/guard.mjs"
          }
        ]
      }
    ]
  }
}
