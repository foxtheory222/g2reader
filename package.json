{
  "name": "g2reader",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "pack": "evenhub pack app.json dist",
    "simulate": "evenhub-simulator http://localhost:5173",
    "pretest": "npm run build && npm run typecheck:test",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "pretest:sim": "npm test",
    "test:sim": "node scripts/test-sim.mjs"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.12",
    "@evenrealities/pretext": "^0.1.4"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.13",
    "@evenrealities/evenhub-simulator": "^0.8.0",
    "@types/node": "^22.19.21",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.10"
  }
}
